# Copy this file to .env and fill in the values you need.
# Lines starting with # are comments; leave optional vars empty or remove them.

# ── Port ──────────────────────────────────────────────────────────────────────
PORT=5300         # port inside the container
HOST_PORT=5300    # port exposed on the Docker host

# ── Anthropic / Claude Code ───────────────────────────────────────────────────
# Required.  Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── API authentication (optional) ────────────────────────────────────────────
# When set, POST /api/run-audit requires an X-API-Key header with this value.
# Leave empty to disable key checking (suitable for LAN-only access).
API_KEY=

# ── DataForSEO (optional) ─────────────────────────────────────────────────────
# Enables /seo dataforseo commands and enriches audits with live SERP data.
# Sign up at https://app.dataforseo.com/register
DATAFORSEO_USERNAME=
DATAFORSEO_PASSWORD=
# Leave empty to enable all 9 API modules, or restrict to a comma-separated list:
# ENABLED_MODULES=SERP,KEYWORDS_DATA,ONPAGE

# ── Google APIs (optional) ────────────────────────────────────────────────────
# Tier 0 — free API key (PageSpeed Insights, CrUX, Knowledge Graph)
# Create at https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_API_KEY=AIzaSy...

# Tier 1+ — service account for Search Console, Indexing API, and GA4
# 1. Create a service account in Google Cloud IAM, download the JSON key.
# 2. Mount the file into the container (see docker-compose.yml volumes section).
# 3. Set this to the in-container path of the mounted file.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/service_account.json

# Default Search Console property (sc-domain:example.com or https://example.com/)
GSC_PROPERTY=

# GA4 numeric property ID (e.g. properties/123456789)  — required for /seo google ga4
GA4_PROPERTY_ID=

# ── Audit settings ────────────────────────────────────────────────────────────
# Directory inside the container where audit history is stored.
AUDIT_DATA_DIR=/data/audits

# Max seconds to wait for a single claude process before killing it (default 90 min).
AUDIT_TIMEOUT_SECONDS=5400
